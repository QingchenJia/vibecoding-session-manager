{
  "name": "vibecoding-session-manager",
  "version": "0.1.0",
  "description": "Terminal tool to manage AI coding agent sessions and skills across Claude Code, Codex (OpenAI), and GitHub Copilot.",
  "type": "module",
  "license": "MIT",
  "author": "QingchenJia",
  "repository": {
    "type": "git",
    "url": "https://github.com/QingchenJia/vibecoding-session-manager"
  },
  "keywords": [
    "cli",
    "ai",
    "coding-agent",
    "session-manager",
    "skill-manager",
    "claude-code",
    "codex",
    "copilot",
    "disk-cleanup",
    "terminal"
  ],
  "bin": {
    "vibe": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "tsx --test tests/*.test.ts",
    "check": "tsc --noEmit",
    "prepare": "tsc"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.0.0",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
